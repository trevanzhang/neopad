{
  "name": "neopad",
  "version": "0.5.3",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "pnpm --filter neopad-app dev",
    "build": "pnpm --filter neopad-app build",
    "check:versions": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/check-versions.ps1",
    "check:release-tag": "node scripts/check-release-tag.mjs",
    "test:frontend": "pnpm --filter neopad-app test",
    "test:all": "cargo test --workspace && pnpm test:frontend",
    "test:e2e:build": "cargo build -p neopad-mcp --release && node scripts/prepare-mcp-sidecar.mjs && pnpm --filter neopad-app tauri build --no-bundle",
    "test:e2e:setup": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/setup-e2e.ps1",
    "test:e2e": "pnpm test:e2e:setup && pnpm test:e2e:build && wdio run ./e2e/wdio.conf.ts",
    "tauri": "pnpm --filter neopad-app tauri",
    "tauri:dev": "pnpm --filter neopad-app tauri dev",
    "tauri:build": "cargo build -p neopad-mcp --release && node scripts/prepare-mcp-sidecar.mjs && node scripts/build-tauri-bundle.mjs"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@wdio/cli": "^9.27.0",
    "@wdio/local-runner": "^9.27.0",
    "@wdio/mocha-framework": "^9.27.0",
    "@wdio/spec-reporter": "^9.27.0"
  }
}
