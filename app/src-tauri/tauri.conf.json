{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NeoPad",
  "version": "0.4.6",
  "identifier": "com.neopad.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "NeoPad",
        "width": 720,
        "height": 520,
        "minWidth": 420,
        "minHeight": 360,
        "resizable": true,
        "center": false,
        "visible": false,
        "decorations": true,
        "zoomHotkeysEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "../../target/release/neopad-mcp"
    ],
    "icon": [
      "icons/icon.ico",
      "icons/icon.icns",
      "icons/32x32.png",
      "icons/128x128.png"
    ],
    "windows": {
      "wix": {
        "template": "wix/main.wxs",
        "bannerPath": "icons/wix-banner.bmp",
        "dialogImagePath": "icons/wix-dialog.bmp"
      }
    }
  }
}
