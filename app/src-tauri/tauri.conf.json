{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NeoPad",
  "version": "0.6.1",
  "identifier": "com.neopad.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "NeoPad",
        "width": 720,
        "height": 520,
        "minWidth": 420,
        "minHeight": 360,
        "resizable": true,
        "center": false,
        "visible": false,
        "decorations": true,
        "dragDropEnabled": false,
        "zoomHotkeysEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self' customprotocol: asset:; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: data: blob:; font-src 'self' data:; connect-src ipc: http://ipc.localhost; object-src 'none'; base-uri 'none'; frame-src 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi"],
    "externalBin": [
      "../../target/release/neopad-mcp"
    ],
    "fileAssociations": [
      {
        "ext": ["md", "markdown"],
        "name": "Markdown document",
        "description": "NeoPad Markdown document",
        "role": "Editor",
        "mimeType": "text/markdown"
      }
    ],
    "icon": [
      "icons/icon.ico",
      "icons/icon.icns",
      "icons/32x32.png",
      "icons/128x128.png"
    ],
    "windows": {
      "wix": {
        "template": "wix/main.wxs",
        "language": {
          "en-US": {
            "localePath": "wix/locales/en-US.wxl"
          }
        },
        "bannerPath": "icons/wix-banner.bmp",
        "dialogImagePath": "icons/wix-dialog.bmp"
      }
    }
  }
}
